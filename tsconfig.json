{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "tsBuildInfoFile": "node_modules/.cache/tsconfig.tsbuildinfo",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "paths": {
      "@shapeshift-labs/frontier-annotations": ["../frontier-annotations/src/index.ts"],
      "@shapeshift-labs/frontier-annotations/*": ["../frontier-annotations/src/*.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../frontier-annotations" }
  ]
}
